{
  "info": {
    "name": "Product/Inventory API - UTS",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Collection untuk pengujian UTS Communication Protocol - Case 2 (Product/Inventory API)"
  },
  "item": [
    {
      "name": "1. GET Daftar Produk",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/products",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "products"
          ]
        }
      },
      "response": []
    },
    {
      "name": "2. GET Detail Produk",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/products/1",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "products",
            "1"
          ]
        }
      },
      "response": []
    },
    {
      "name": "3. POST Tambah Produk",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Smartwatch AI\",\n  \"category\": \"wearable\",\n  \"price\": 2000000,\n  \"stock\": 15\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/products",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "products"
          ]
        }
      },
      "response": []
    },
    {
      "name": "4. PATCH Update Stok",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"stock\": 10\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/products/1",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "products",
            "1"
          ]
        }
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8088",
      "type": "string"
    }
  ]
}
